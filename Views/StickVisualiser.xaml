<UserControl x:Class="XboxControllerStudio.Views.StickVisualiser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="120"
            Height="120">

      <!-- Outer circle = boundary ring -->
      <Canvas x:Name="Canvas"
                  Width="120"
                  Height="120">
            <Ellipse Width="120"
                        Height="120"
                     Stroke="{StaticResource BrushSeparator}"
                     StrokeThickness="1.5"
                     Fill="{StaticResource BrushSurface}"/>

            <!-- Deadzone ring (scaled by DeadzoneRadius) -->
            <Ellipse x:Name="DeadzoneRing"
                     Stroke="{StaticResource BrushAccentDim}"
                     StrokeThickness="1.2"
                     Fill="#114A8DFF"/>

            <!-- Cross-hair lines -->
            <Line X1="60"
                        Y1="10"
                        X2="60"
                        Y2="110"
                  Stroke="{StaticResource BrushSeparator}"
                  StrokeThickness="0.8"
                        Opacity="0.4"/>
            <Line X1="10"
                        Y1="60"
                        X2="110"
                        Y2="60"
                  Stroke="{StaticResource BrushSeparator}"
                  StrokeThickness="0.8"
                        Opacity="0.4"/>

            <!-- Dot representing stick position -->
            <Ellipse x:Name="Dot"
                     Width="14"
                        Height="14"
                     Fill="{StaticResource BrushAccent}"/>
      </Canvas>
</UserControl>
