<UserControl x:Class="XboxControllerStudio.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">

    <UserControl.Resources>
        <Style x:Key="StyleLanguageComboItem"
               TargetType="ComboBoxItem">
            <Setter Property="Foreground"
                    Value="#FF101010"/>
            <Setter Property="Background"
                    Value="#FFF2F4F8"/>
            <Setter Property="Padding"
                    Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFDCE4F5"/>
                </Trigger>
                <Trigger Property="IsSelected"
                         Value="True">
                    <Setter Property="Background"
                            Value="#FFC7D7F7"/>
                    <Setter Property="Foreground"
                            Value="#FF101010"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource SettingsTitle}"
                   Style="{StaticResource StylePageHeader}"
                   Margin="0,0,0,18"/>

        <Border Grid.Row="1"
                Style="{StaticResource StyleGlassCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{DynamicResource Language}"
                               Style="{StaticResource StyleSectionHeader}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding SupportedLanguages}"
                              SelectedValuePath="Code"
                              DisplayMemberPath="DisplayName"
                              SelectedValue="{Binding SelectedLanguageCode}"
                              Background="#FFF2F4F8"
                              Foreground="#FF101010"
                              ItemContainerStyle="{StaticResource StyleLanguageComboItem}"
                              BorderBrush="{StaticResource BrushSeparator}"
                              Padding="8,6"
                              Margin="0,0,0,16"/>

                    <!-- Polling interval -->
                    <TextBlock Text="{DynamicResource PollingInterval}"
                               Style="{StaticResource StyleSectionHeader}"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Value="{Binding PollingIntervalMs}"
                                Minimum="1"
                                Maximum="100"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Style="{StaticResource StyleSlider}"
                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PollingIntervalMs, StringFormat='{}{0} ms'}"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                    </Grid>

                    <!-- Low battery alerts -->
                    <TextBlock Text="{DynamicResource LowBatteryNotification}"
                               Style="{StaticResource StyleSectionHeader}"
                               Margin="0,0,0,8"/>

                    <CheckBox Content="{DynamicResource EnableLowBatteryNotifications}"
                              IsChecked="{Binding LowBatteryNotificationsEnabled}"
                              Foreground="{StaticResource BrushTextPrimary}"
                              Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="58"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Value="{Binding LowBatteryThresholdPercent}"
                                Minimum="10"
                                Maximum="90"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Style="{StaticResource StyleSlider}"
                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LowBatteryThresholdPercent, StringFormat='{}{0}%'}"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                    </Grid>

                    <!-- Start with Windows -->
                    <CheckBox Content="{DynamicResource StartWithWindows}"
                              IsChecked="{Binding StartWithWindows}"
                              Foreground="{StaticResource BrushTextPrimary}"
                              Margin="0,0,0,12"/>

                    <!-- Minimize to tray -->
                    <CheckBox Content="{DynamicResource MinimizeToTray}"
                              IsChecked="{Binding MinimizeToTray}"
                              Foreground="{StaticResource BrushTextPrimary}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
